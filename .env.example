# --- Clerk (required for sign-in) — https://clerk.com/docs/react/getting-started/quickstart
# Use VITE_ prefix (Vite). Do not use NEXT_PUBLIC_* (that is for Next.js only).
VITE_CLERK_PUBLISHABLE_KEY=

# --- Frontend (Vite) ---
# Leave empty on Vercel: the app uses same-origin /api (serverless Express).
# Set only if the API is on another origin (e.g. http://localhost:4000 for local API only).
VITE_API_URL=

# Where Vite proxies /api/* (local dev only)
API_PROXY_TARGET=http://localhost:4000

# --- Vercel / production (set in Vercel Project → Environment Variables, not only here) ---
# DATABASE_URL, DIRECT_URL, JWT_SECRET, CLERK_SECRET_KEY, CLIENT_ORIGIN — see server/.env.example
