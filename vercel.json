{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["iad1"],
  "rewrites": [
    {
      "source": "/((?!api(?:/|$)).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/[[...path]].ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "server/src/generated/**"
    }
  }
}
