{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["iad1"],
  "rewrites": [
    {
      "source": "/((?!api(?:/|$)).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/health.ts": { "maxDuration": 10, "memory": 256 },
    "api/flights.ts": { "maxDuration": 10, "memory": 256 },
    "api/flights/serp.ts": { "maxDuration": 15, "memory": 256 },
    "api/flights/explore.ts": { "maxDuration": 15, "memory": 256 },
    "api/bookings.ts": { "maxDuration": 10, "memory": 256 },
    "api/bookings/my.ts": { "maxDuration": 10, "memory": 256 },
    "api/auth/register.ts": { "maxDuration": 10, "memory": 256 },
    "api/auth/login.ts": { "maxDuration": 10, "memory": 256 }
  }
}
