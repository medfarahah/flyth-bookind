# Neon: pooled connection for the app + PrismaClient (hostname contains "-pooler")
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"

# Neon: direct connection for Prisma CLI (migrate, db push) — no "-pooler" in hostname
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

JWT_SECRET="change-this-to-a-long-random-string"

# Clerk — https://dashboard.clerk.com → API keys → Secret keys (for session JWT verification)
CLERK_SECRET_KEY=
PORT=4000
# Comma-separated if needed, e.g. Vite preview: http://localhost:5173,http://localhost:4173
CLIENT_ORIGIN="http://localhost:5173"

# Optional: SerpAPI (Google Flights + Google Travel Explore) — https://serpapi.com/manage-api-key
SERPAPI_API_KEY=
